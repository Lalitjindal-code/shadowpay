# --- ShadowPay Master Gitignore ---

# Environment files - CRITICAL: Never commit these
.env
.env.local
.env.production
.env.test
.env*.local
**/.env
**/.env.local
**/.env*.local

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js Build & Outputs
.next/
**/.next/
out/
build/
dist/
**/dist/

# Solana & Anchor Build
target/
**/target/
test-ledger/
*.so
**/*-keypair.json
Cargo.lock (opt-in, usually keep in root, but Anchor has its own)

# IDE and OS Files
.DS_Store
.vscode/
.idea/
*.swp
*.bak
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# Other
*.pem
next-env.d.ts
